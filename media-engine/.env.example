# ======================================================
# Gremio Estelar — Media Engine (.env.example)
# Copy this file to .env and fill in your values
# ======================================================

# ── FastAPI ─────────────────────────────────────────────
DEBUG=false
PORT=8001

# ── Cloudflare R2 ──────────────────────────────────────
# Get these from Cloudflare Dashboard → R2 → Account API Tokens
# Endpoint: R2 → Bucket → Settings → S3 API URL
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key_here
R2_SECRET_KEY=your_secret_key_here

# Bucket name (must already exist in R2)
R2_BUCKET=gremio-estelar-media

# Public URL — enable Public Development URL in R2 Bucket Settings
# or use a custom domain
R2_PUBLIC_URL=https://pub-your-public-url.r2.dev
