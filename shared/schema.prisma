// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  // LOCAL DEV: SQLite (no server required)
  // PRODUCTION: Switch provider to "postgresql" and update DATABASE_URL
  // NOTE: SQLite does not support enums, so role/status/provider are String fields
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String         @unique
  role          String         @default("USER")
  status        String         @default("PENDING")
  provider      String         @default("EMAIL")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  password      String?
  vtuberProfile VTuberProfile?
  refreshTokens RefreshToken[]

  @@index([username])
}

model RefreshToken {
  id          String   @id @default(cuid())
  hashedToken String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked     Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VTuberProfile {
  id          String   @id @default(cuid())
  displayName String
  avatarUrl   String?
  description String?
  socialLinks String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique

  @@index([displayName])
}
