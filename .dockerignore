# ============================================================
# Gremio Estelar — Docker Build Context Ignore
# ============================================================
# Without this file, the Docker daemon receives the ENTIRE
# project directory (including node_modules, .git, build
# artifacts), dramatically slowing down every build.
# ============================================================

# ── Dependencies (hundreds of MB!) ──────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
shared/node_modules/

# ── Version control ─────────────────────────────────────────
.git/
.gitattributes
.gitignore

# ── Environment files (also a SECURITY risk!) ───────────────
.env
.env.*
!.env.example

# ── Build artifacts ─────────────────────────────────────────
dist/
.next/
backend/dist/
frontend/.next/
frontend/out/
*.tsbuildinfo

# ── Logs ────────────────────────────────────────────────────
*.log
server*.log

# ── Uploaded files (dev only) ───────────────────────────────
uploads/
backend/uploads/

# ── OS / editor files ───────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE / tooling ───────────────────────────────────────────
.idea/
.vscode/
.aider*
nul

# ── Coverage reports ────────────────────────────────────────
coverage/

# ── Python / virtualenv ─────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
