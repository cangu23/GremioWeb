  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate-dev": "prisma migrate dev --name add_last_live_at --schema prisma/schema.prisma",
    "start": "node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
